<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="xarm_1s">

  <material name="black">
    <color rgba="0.2 0.2 0.2 1"/>
  </material>
  <material name="blue">
    <color rgba="0.3 0.5 0.9 1"/>
  </material>

  <!-- Base link of the arm (mount point) -->
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0.0028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/base.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0028" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot_description/meshes/base_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 6 -->
  <joint name="arm6" type="revolute">
    <parent link="arm_base"/>
    <child link="link6"/>
    <origin xyz="0 0 0.043" rpy="0 0 3.1416"/>
    <axis xyz="0 0 -1"/>
    <limit effort="1000" lower="-2.1" upper="2.1" velocity="1.0"/>
  </joint>

  <link name="link6">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link6.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link6_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 5 -->
  <joint name="arm5" type="revolute">
    <parent link="link6"/>
    <child link="link5"/>
    <origin xyz="0.002 0 0.032" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" lower="-1.5708" upper="1.5708" velocity="1.0"/>
  </joint>

  <link name="link5">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link5.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link5_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 4 -->
  <joint name="arm4" type="revolute">
    <parent link="link5"/>
    <child link="link4"/>
    <origin xyz="0 0 0.09775" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="1000" lower="-2.09" upper="2.09" velocity="1.0"/>
  </joint>

  <link name="link4">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link4.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link4_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 3 -->
  <joint name="arm3" type="revolute">
    <parent link="link4"/>
    <child link="link3"/>
    <origin xyz="0 0 0.099" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1000" lower="-1.85" upper="2.07" velocity="1.0"/>
  </joint>

  <link name="link3">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link3.stl"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link3_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 2 -->
  <joint name="arm2" type="revolute">
    <parent link="link3"/>
    <child link="link2"/>
    <origin xyz="-0.00125 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="-1.95" upper="1.95" velocity="1.0"/>
  </joint>

  <link name="link2">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link2.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link2_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Joint 1 -->
  <joint name="arm1" type="revolute">
    <parent link="link2"/>
    <child link="link1"/>
    <origin xyz="-0.0015 -0.014 0.0315" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000" lower="0" upper="1.8326" velocity="1.0"/>
  </joint>

  <link name="link1">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link1.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link1_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Arm1 left duplicate -->
  <joint name="arm1_left" type="continuous">
    <parent link="link2"/>
    <child link="link1_left"/>
    <origin xyz="-0.0015 0.014 0.0315" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <mimic joint="arm1" multiplier="-1" offset="0"/>
  </joint>

  <link name="link1_left">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link1_left.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link1_left_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- Arm0 and left duplicate -->
  <joint name="arm0" type="continuous">
    <parent link="link1"/>
    <child link="link0"/>
    <origin xyz="-0.0023 0 0.0305" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <mimic joint="arm1" multiplier="-1.01" offset="-0.3"/>
  </joint>

  <link name="link0">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link0.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link0_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <joint name="arm0_left" type="continuous">
    <parent link="link1_left"/>
    <child link="link0_left"/>
    <origin xyz="-0.0023 0 0.0305" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <mimic joint="arm1" multiplier="1.01" offset="0.3"/>
  </joint>

  <link name="link0_left">
    <visual>
      <geometry>
        <mesh filename="package://robot_description/meshes/link0_left.stl"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://robot_description/meshes/link0_left_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <!-- ros2_control block -->
  <ros2_control name="xarm_1s" type="system">
    <hardware>
      <plugin>ros2_control_xarm_1s/XArm1SSystemHardware</plugin>
    </hardware>
    <joint name="arm6">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm5">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm4">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm3">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm2">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm1">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="arm0">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

</robot>