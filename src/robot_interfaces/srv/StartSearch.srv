# Foxglove-friendly wrapper for the WskrSearch action. Mirrors the
# WskrSearch.action Goal fields verbatim so the dashboard can dispatch
# either a TOY (0) or BOX (1) search with a timeout.
uint8 TARGET_TOY=0
uint8 TARGET_BOX=1
uint8 target_type
uint8 target_id
float32 timeout_sec
---
bool accepted       # true if the action server accepted the goal
string message
