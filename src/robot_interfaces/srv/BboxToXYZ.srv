# Request: bounding-box fields from GetObjProperties + image dimensions for normalisation
float32 bbox_x          # centre x (raw pixel or normalised [0-1])
float32 bbox_y          # centre y (raw pixel or normalised [0-1])
float32 bbox_width      # box width  (same units as bbox_x/y)
float32 bbox_height     # box height (same units as bbox_x/y)
int32   image_width     # image width in pixels  (0 = already normalised)
int32   image_height    # image height in pixels (0 = already normalised)
---
# Response: object position in arm world-frame (mm)
bool    success
float32 x_mm
float32 y_mm
float32 z_mm
