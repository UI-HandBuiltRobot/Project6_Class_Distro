# Goal: Search for a target object by wandering and looking
uint8 TARGET_TOY=0
uint8 TARGET_BOX=1
uint8 target_type
uint8 target_id
float32 timeout_sec
---
# Result: Detection found (if successful)
bool success
robot_interfaces/ImgDetectionData detected_object
---
# Feedback: Progress updates during search
float32 elapsed_sec
string current_phase
int32 detections_sampled
